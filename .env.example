PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=project_task_db
JWT_SECRET=replace-with-a-random-string-min-32-chars
JWT_EXPIRES_IN=7d
NODE_ENV=development

CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
BCRYPT_SALT_ROUNDS=10
API_PREFIX=/api/v1
DOCS_PATH=/docs
HEALTH_PATH=/health
APP_HOST=localhost
APP_URL=http://localhost

LOGGER_ERROR_PATH=logs/error.log
LOGGER_COMBINED_PATH=logs/combined.log
LOGGER_SERVICE_NAME=project-task-api

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=user123

DEFAULT_PAGE_LIMIT=10
MAX_PAGE_LIMIT=100
